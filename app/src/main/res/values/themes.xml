<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ShanghaiPrimary" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/md_primary</item>
        <item name="android:navigationBarColor">@android:color/white</item>
    </style>

    <style name="Theme.ShanghaiPrimary.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ShanghaiPrimary</item>
    </style>
</resources>
