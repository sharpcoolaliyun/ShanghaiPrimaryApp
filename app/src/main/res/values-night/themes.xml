<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ShanghaiPrimary" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/md_background_dark</item>
        <item name="android:statusBarColor">@color/md_primary</item>
    </style>
    <style name="Theme.ShanghaiPrimary.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/md_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ShanghaiPrimary</item>
    </style>
</resources>
